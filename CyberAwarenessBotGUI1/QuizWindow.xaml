<Window x:Class="CyberAwarenessBotGUI1.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Quiz" Height="400" Width="500" Background="#2d2d2d">
    <StackPanel Margin="20">
        <TextBlock x:Name="txtQuestion" Text="Question" FontSize="18" Foreground="White" Margin="0,0,0,20" TextWrapping="Wrap"/>
        <StackPanel x:Name="stackAnswers"/>
        <TextBlock x:Name="txtFeedback" Margin="0,20,0,0" Foreground="Cyan" TextWrapping="Wrap"/>
        <Button x:Name="btnNext" Content="Next Question" Margin="0,20,0,0" Click="BtnNext_Click" Visibility="Collapsed"/>
    </StackPanel>
</Window>
